{
  "workflowId": "cluster.governance.decision",
  "type": "LONG_RUNNING",
  "version": 1,
  "steps": [
    { "stepId": "simulate", "type": "ENGINE", "engine": "t3i.governance.cluster" },
    { "stepId": "evaluate", "type": "ENGINE", "engine": "t0u.governance.cluster" },
    { "stepId": "approve", "type": "COMMAND", "engine": "governance.cluster" },
    { "stepId": "execute", "type": "COMMAND", "engine": "governance.cluster" },
    { "stepId": "reject", "type": "COMPENSATION", "engine": "governance.cluster" }
  ],
  "transitions": [
    { "from": "simulate", "to": "evaluate" },
    { "from": "evaluate", "to": "approve", "on": "ALLOW" },
    { "from": "evaluate", "to": "reject", "on": "DENY" },
    { "from": "approve", "to": "execute" }
  ]
}
