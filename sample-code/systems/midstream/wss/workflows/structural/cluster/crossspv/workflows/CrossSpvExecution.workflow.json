{
  "workflowId": "cluster.crossspv.execution",
  "type": "LONG_RUNNING",
  "version": 1,
  "steps": [
    {
      "stepId": "prepare",
      "type": "COMMAND",
      "engine": "crossspv",
      "command": "PrepareCrossSpvTransactionCommand"
    },
    {
      "stepId": "execute",
      "type": "PROCESS",
      "handler": "CrossSpvProcessManager"
    },
    {
      "stepId": "commit",
      "type": "COMMAND",
      "engine": "crossspv",
      "command": "CommitCrossSpvTransactionCommand"
    },
    {
      "stepId": "fail",
      "type": "COMPENSATION",
      "engine": "crossspv",
      "command": "FailCrossSpvTransactionCommand"
    }
  ],
  "transitions": [
    { "from": "prepare", "to": "execute" },
    { "from": "execute", "to": "commit", "on": "SUCCESS" },
    { "from": "execute", "to": "fail", "on": "FAILURE" }
  ]
}
