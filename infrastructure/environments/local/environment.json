{
  "environment": "local",
  "classification": "operational-system",
  "context": "deployment",
  "domain": "sandbox",
  "settings": {
    "kafka": {
      "bootstrap_servers": "localhost:29092",
      "partitions": 12,
      "replication_factor": 1
    },
    "postgres": {
      "event_store": {
        "host": "localhost",
        "port": 5432,
        "database": "whyce_eventstore",
        "user": "whyce"
      },
      "projections": {
        "host": "localhost",
        "port": 5434,
        "database": "whyce_projections",
        "user": "whyce"
      },
      "whycechain": {
        "host": "localhost",
        "port": 5433,
        "database": "whycechain",
        "user": "whyce"
      }
    },
    "redis": {
      "host": "localhost",
      "port": 6379
    },
    "opa": {
      "host": "localhost",
      "port": 8181
    },
    "minio": {
      "endpoint": "localhost:9000",
      "console": "localhost:9001"
    },
    "observability": {
      "prometheus": "localhost:9090",
      "grafana": "localhost:3000"
    }
  }
}
