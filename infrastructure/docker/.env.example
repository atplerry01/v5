# .env.example — copy to .env.local (which MUST stay gitignored per R-CFG-R1)
# and fill in before invoking docker-compose.validation.yml.
#
# .env.local is colocated with docker-compose.validation.yml and auto-loaded
# by compose when run from this directory (or when --env-file points here).
#
# Invocation pattern used by scripts/infra/compose-up.sh:
#   docker compose \
#     --env-file infrastructure/docker/.env.local \
#     -f infrastructure/docker/docker-compose.validation.yml up -d

POSTGRES_PASSWORD=
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
JWT_SIGNING_KEY=
