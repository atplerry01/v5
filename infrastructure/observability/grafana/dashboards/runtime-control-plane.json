{
  "annotations": { "list": [] },
  "editable": false,
  "graphTooltip": 1,
  "title": "Runtime — Control Plane",
  "tags": ["whycespace", "runtime", "r4a"],
  "timezone": "utc",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "description": "Canonical runtime control-plane dashboard. Command throughput, failure taxonomy, posture, admission/backpressure, breaker-by-degraded-mode, and operator-action activity. Source meters: Whycespace.Runtime.ControlPlane, Whycespace.Runtime.Enforcement, Whycespace.Intake, Whycespace.Postgres, prometheus-net HTTP. R4.A packaging — all PromQL refers to existing metrics; no new labels introduced.",
  "panels": [
    {
      "id": 1,
      "title": "Command throughput (rps, by classification)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum by (classification) (rate(whyce_runtime_command_total_total[1m]))", "legendFormat": "{{classification}}" }
      ]
    },
    {
      "id": 2,
      "title": "Command latency p50/p95/p99 (ms)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(whyce_runtime_command_duration_ms_bucket[5m])))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(whyce_runtime_command_duration_ms_bucket[5m])))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(whyce_runtime_command_duration_ms_bucket[5m])))", "legendFormat": "p99" }
      ]
    },
    {
      "id": 3,
      "title": "Command failure rate",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum(rate(whyce_runtime_command_failed_total[5m])) / clamp_min(sum(rate(whyce_runtime_command_total_total[5m])), 1)", "legendFormat": "failure rate" }
      ]
    },
    {
      "id": 4,
      "title": "HTTP request rate by status class",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum by (status_code) (rate(request_count_total[1m]))", "legendFormat": "{{status_code}}" }
      ]
    },
    {
      "id": 5,
      "title": "HTTP latency p95 (s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(request_duration_seconds_bucket[5m])))", "legendFormat": "p95" }
      ]
    },
    {
      "id": 6,
      "title": "Intake admission (admitted vs rejected)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum(rate(intake_admitted_total[1m]))", "legendFormat": "admitted" },
        { "expr": "sum by (partition) (rate(intake_rejected_total[1m]))", "legendFormat": "rejected/{{partition}}" },
        { "expr": "sum(rate(intake_queue_full_total[1m]))", "legendFormat": "queue full" }
      ]
    },
    {
      "id": 7,
      "title": "Enforcement activity (by action)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 24, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum by (action) (rate(whyce_enforcement_actions_count_total[5m]))", "legendFormat": "{{action}}" }
      ]
    },
    {
      "id": 8,
      "title": "Policy evaluation — timeouts / breaker-open / failures",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 24, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum(rate(policy_evaluate_timeout_total[5m]))", "legendFormat": "timeout" },
        { "expr": "sum(rate(policy_evaluate_breaker_open_total[5m]))", "legendFormat": "breaker open" },
        { "expr": "sum(rate(policy_evaluate_failure_total[5m]))", "legendFormat": "failure" }
      ]
    },
    {
      "id": 9,
      "title": "Operator actions (R4.B) — rate by action_type × outcome",
      "description": "R4.A packaging-discovered metric. Surfaces every accepted / refused / failed operator action across the admin surface. Low-cardinality: action_type is a fixed set (outbound-effect.reconcile, dlq.redrive, workflow.{resume,approve,reject}); outcome is {accepted, refused, failed}.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 32, "w": 24, "h": 8 },
      "targets": [
        { "expr": "sum by (action_type, outcome) (rate(whyce_runtime_operator_action_total_total[5m]))", "legendFormat": "{{action_type}} / {{outcome}}" }
      ]
    }
  ]
}
