{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "title": "Phase 3 Resilience — Economic System",
  "tags": ["phase3-resilience", "economic-system", "whycespace"],
  "timezone": "utc",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Dispatch latency (avg / p95 / p99)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(runtime_dispatch_latency_ms_bucket[5m])))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(runtime_dispatch_latency_ms_bucket[5m])))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(runtime_dispatch_latency_ms_bucket[5m])))", "legendFormat": "p99" }
      ]
    },
    {
      "id": 2,
      "title": "Dispatch throughput (req/s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum(rate(runtime_dispatch_total[1m]))", "legendFormat": "req/s" }
      ]
    },
    {
      "id": 3,
      "title": "Dispatch error rate",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum(rate(runtime_dispatch_errors_total[5m])) / sum(rate(runtime_dispatch_total[5m]))", "legendFormat": "error rate" }
      ]
    },
    {
      "id": 4,
      "title": "Phase 3 anomalies (spike + burst)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum(phase3_latency_spike_total)", "legendFormat": "latency spikes" },
        { "expr": "sum(phase3_error_burst_total)", "legendFormat": "error bursts" }
      ]
    },
    {
      "id": 5,
      "title": "Soak — process memory",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 8 },
      "targets": [
        { "expr": "process_resident_memory_bytes", "legendFormat": "resident bytes" }
      ]
    }
  ]
}
