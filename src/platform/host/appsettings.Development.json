{
  "_comment": "Local-dev overrides. Used only when ASPNETCORE_ENVIRONMENT=Development.",
  "Kafka": {
    "BootstrapServers": "localhost:29092"
  },
  "Redis": {
    "ConnectionString": "localhost:6379"
  },
  "Opa": {
    "Endpoint": "http://localhost:8181",
    "RequestTimeoutMs": 750
  },
  "MinIO": {
    "Endpoint": "localhost:9000",
    "AccessKey": "${MINIO_ROOT_USER}",
    "SecretKey": "${MINIO_ROOT_PASSWORD}",
    "UseSsl": false
  },
  "WhycePolicy": {
    "Version": "v1"
  },
  "Postgres": {
    "ConnectionString": "Host=localhost;Port=5432;Database=whyce_eventstore;Username=whyce;Password=${POSTGRES_PASSWORD}",
    "ChainConnectionString": "Host=localhost;Port=5433;Database=whycechain;Username=whyce;Password=${POSTGRES_PASSWORD}",
    "ProjectionsConnectionString": "Host=localhost;Port=5434;Database=whyce_projections;Username=whyce;Password=${POSTGRES_PASSWORD}"
  },
  "Projections": {
    "ConnectionString": "Host=localhost;Port=5434;Database=whyce_projections;Username=whyce;Password=${POSTGRES_PASSWORD}"
  },
  "Jwt": {
    "SigningKey": "${JWT_SIGNING_KEY}"
  },
  "Auth": {
    "DevMode": true
  }
}
