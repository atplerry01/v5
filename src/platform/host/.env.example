# WBSM v3 host — required environment variables.
#
# Copy this file to `.env` and fill in values for your local environment.
# `.env` is gitignored. NEVER commit credentials or endpoints to appsettings.json.
#
# Defaults below match infrastructure/deployment/docker-compose.yml. With the
# stack running locally (`docker compose up`), these values will work as-is.
# In all other environments these MUST be overridden.
#
# Composition root (InfrastructureComposition.cs, TodoBootstrap.cs, TodoController.cs)
# throws InvalidOperationException at startup if any required key is missing —
# there are no fallbacks.

# --- JWT Authentication (WP-1) ---
# HMAC-SHA256 signing key. Must be at least 32 characters.
# In production, use a strong random key from a secrets manager.
JWT__SigningKey=CHANGE_ME_minimum_32_characters_long_secret_key

# --- Event store (Postgres) ---
Postgres__ConnectionString=Host=localhost;Port=5432;Database=whyce_eventstore;Username=whyce;Password=whyce

# --- Projections (Postgres, separate cluster) ---
# Note: TodoBootstrap.cs reads Postgres__ProjectionsConnectionString,
# TodoController.cs reads Projections__ConnectionString. Both currently point
# at the same database. Unifying these key names is tracked as a follow-up.
Postgres__ProjectionsConnectionString=Host=localhost;Port=5434;Database=whyce_projections;Username=whyce;Password=whyce
Projections__ConnectionString=Host=localhost;Port=5434;Database=whyce_projections;Username=whyce;Password=whyce

# --- Kafka ---
Kafka__BootstrapServers=localhost:29092

# --- Redis ---
Redis__ConnectionString=localhost:6379

# --- OPA policy evaluator ---
OPA__Endpoint=http://localhost:8181

# --- MinIO object storage ---
MinIO__Endpoint=localhost:9000
MinIO__AccessKey=whyce
MinIO__SecretKey=whycepassword
